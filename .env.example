# Shared
APP_ENV=dev
APP_NAME=Sentinel
APP_BASE_URL=https://sentinel.vaultrix.in
API_BASE_URL=https://api.sentinel.vaultrix.in

# Backend
DATABASE_URL=postgresql+psycopg://aks_governance:aks_governance@localhost:5432/aks_governance
REDIS_URL=redis://localhost:6379/0
BACKEND_CORS_ORIGINS=["https://sentinel.vaultrix.in","http://sentinel.vaultrix.in"]
SESSION_SECRET=replace-with-32-byte-random-secret
DEMO_MODE=true
AUTO_CREATE_SCHEMA=false
LOG_LEVEL=INFO

# Microsoft Entra ID
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=
AZURE_AUTHORITY=https://login.microsoftonline.com/00000000-0000-0000-0000-000000000000/v2.0
AZURE_API_AUDIENCE=api://00000000-0000-0000-0000-000000000000
AZURE_ALLOWED_TENANTS=00000000-0000-0000-0000-000000000000
AZURE_OPERATION_AUTH_MODE=default_credential
AZURE_SUBSCRIPTION_IDS=

# Frontend
NEXT_PUBLIC_API_BASE_URL=https://api.sentinel.vaultrix.in/api/v1
NEXT_PUBLIC_AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
NEXT_PUBLIC_AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
NEXT_PUBLIC_AZURE_API_SCOPE=api://00000000-0000-0000-0000-000000000000/access_as_user
NEXT_PUBLIC_AZURE_REDIRECT_URI=https://sentinel.vaultrix.in/auth/callback
NEXT_PUBLIC_DEMO_MODE=true
